# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# --- App ---
APP_ENV=development
APP_PORT=8080

# --- Database (Neon PostgreSQL) ---
# Get this from your Neon project dashboard -> Connection Details.
# Must include sslmode=require for Neon.
# Example:
# DATABASE_URL=postgresql://neondb_owner:password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Connection pool tuning (optional — sensible defaults are used if unset)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MINUTES=5

# --- Auth ---
# Generate with: openssl rand -base64 48
# Must be at least 32 characters — the app refuses to start otherwise.
JWT_SECRET=
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=30
